APP_ENV=production
APP_DEBUG=false
APP_URL=https://calendar.example.com/selfhdb
APP_TIMEZONE=UTC
APP_FORCE_HTTPS=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=selfhdb
DB_USER=selfhdb_user
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

ACCESS_TOKEN_SECRET=change-this-long-random-string
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_REFRESH_PER_15_MIN=20
RATE_LIMIT_SYNC_PUSH_PER_MINUTE=100
RATE_LIMIT_SYNC_PULL_PER_MINUTE=120

SYNC_PULL_LIMIT=200
MAX_JSON_BODY_BYTES=262144
