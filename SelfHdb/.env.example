NODE_ENV=development
HOST=0.0.0.0
PORT=4318
PUBLIC_BASE_URL=http://localhost:4318
ALLOW_INSECURE_HTTP=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_URL=postgres://calendar:calendar@postgres:5432/calendar_app

# Base64-encoded 32-byte secrets.
BACKEND_MASTER_KEY_BASE64=replace_with_32_byte_base64_key
ACCESS_TOKEN_SECRET_BASE64=replace_with_32_byte_base64_key
REQUEST_SIGNING_SECRET_BASE64=replace_with_32_byte_base64_key

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_SESSION_TTL_SECONDS=2592000
AUTH_FLOW_TTL_SECONDS=600
PAIRING_CODE_TTL_SECONDS=600
PAIRING_BOOTSTRAP_TTL_SECONDS=600
STEP_UP_TTL_SECONDS=300
REQUEST_SKEW_SECONDS=300
SYNC_PULL_LIMIT=250

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4318/v1/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4318/v1/auth/microsoft/callback
